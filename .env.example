# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=video_pipeline

# Redis
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true
REDIS_STRICT_MODE=true  # Set to true to fail startup if Redis unavailable

# Groq Whisper API
GROQ_API_KEY=your_groq_api_key_here
GROQ_WHISPER_MODEL=whisper-large-v3
GROQ_CHUNK_DURATION=600
GROQ_CHUNK_OVERLAP=5
GROQ_MAX_FILE_SIZE_MB=25
TRANSCRIPTION_BACKEND=groq
TRANSCRIPT_SERVICE_BASE_URL=http://localhost:8346
TRANSCRIPT_SERVICE_API_KEY=
TRANSCRIPT_SERVICE_POLL_INTERVAL_SEC=2.0
TRANSCRIPT_SERVICE_TIMEOUT_SEC=300

API_KEY=test-key-123
